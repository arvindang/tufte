{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2018"],
    "strict": true,
    "allowJs": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "noEmit": true
  },
  "include": ["main.ts"]
}
